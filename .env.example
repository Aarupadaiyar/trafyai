# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/trafy_intelligence"

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Admin access ──────────────────────────────────────────
# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS="you@trafy.ai,cofounder@trafy.ai"

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
DIGEST_FROM_EMAIL="digest@trafy.ai"

# ── Cron protection ───────────────────────────────────────
# Sent as `Authorization: Bearer <CRON_SECRET>` by Vercel Cron
CRON_SECRET="generate-a-random-string"

# ── Scraper source API keys (optional, only if a source needs one) ──
ARXIV_API_BASE="http://export.arxiv.org/api/query"
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://trafy.ai/intelligence"
